# ─────────────────────────────────────────────────────────────────
# OnFix marketing site — environment variables
# Copy to .env.local for local dev. Production values live in Vercel.
# ─────────────────────────────────────────────────────────────────

# ERP backend the marketing site reads plans/tenants from.
# api.onfixpos.com is LIVE (ERP v1.2.0, 2026-05-25) — use it directly.
NEXT_PUBLIC_ERP_API_BASE=https://api.onfixpos.com

# Apex this marketing site is deployed to. Used in canonical URLs / SEO.
NEXT_PUBLIC_SITE_URL=https://onfixpos.com

# Tenant subdomain template — {slug} is replaced at runtime in /login redirect.
NEXT_PUBLIC_TENANT_URL_TEMPLATE=https://{slug}.onfixpos.com

# ─────────────────────────────────────────────────────────────────
# Payload CMS (Phase 2+; safe to leave blank during Phase 1)
# ─────────────────────────────────────────────────────────────────

# Long random string. Generate with: openssl rand -base64 32
PAYLOAD_SECRET=

# SQLite file path for the CMS DB.
DATABASE_URI=file:./onfix-cms.sqlite

# Cloudflare R2 (S3-compatible) for media uploads.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=onfix-marketing
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.onfixpos.com

# ─────────────────────────────────────────────────────────────────
# Contact form delivery (Phase 1)
# ─────────────────────────────────────────────────────────────────

# If set, contact form posts via Resend; otherwise falls back to mailto:.
RESEND_API_KEY=
CONTACT_DESTINATION_EMAIL=hello@onfixpos.com
